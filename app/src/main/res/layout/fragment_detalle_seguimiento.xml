<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/imagenTMDB"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#DDDDDD" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tituloDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#000000"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/subtituloTMDB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cargando información..."
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de visualización"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/fechaDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YYYY-MM-DD"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Puntuación"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <RatingBar
            android:id="@+id/ratingDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:isIndicator="true"
            android:progressTint="#FFCC00"
            android:secondaryProgressTint="#FFCC00"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/labelImagenRecuerdo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Imagen de recuerdo"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardImagenRecuerdo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <ImageView
                android:id="@+id/imagenRecuerdoDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
