<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pendientes"
        android:textStyle="bold"
        android:textSize="26sp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:textColor="#000000"/>

    <!-- Estado vacÃ­o -->
    <LinearLayout
        android:id="@+id/estadoVacio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Tu lista por ver esta vacia!"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Añade peliculas que te gustaria ver."
            android:textSize="14sp"
            android:textColor="#777777"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnVerPeliculas"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="VER TODAS LAS PELICULAS"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:backgroundTint="#FFCC00"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- Lista con contenido -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listaPendientes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

</LinearLayout>


</layout>
